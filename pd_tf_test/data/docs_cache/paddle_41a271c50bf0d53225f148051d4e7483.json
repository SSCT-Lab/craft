class=\"p\">,</span><span class=\"mi\">2</span><span class=\"p\">],</span>\n<span class=\"gp\">... </span>                       <span class=\"p\">[</span><span class=\"mi\">4</span><span class=\"p\">,</span><span class=\"mi\">7</span><span class=\"p\">,</span><span class=\"mi\">7</span><span class=\"p\">,</span><span class=\"mi\">9</span><span class=\"p\">],</span>\n<span class=\"gp\">... </span>                       <span class=\"p\">[</span><span class=\"mi\">1</span><span class=\"p\">,</span><span class=\"mi\">7</span><span class=\"p\">,</span><span class=\"mi\">0</span><span class=\"p\">,</span><span class=\"mi\">6</span><span class=\"p\">]]],</span>\n<span class=\"gp\">... </span>                     <span class=\"n\">dtype</span><span class=\"o\">=</span><span class=\"s1\">'float32'</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">out1</span> <span class=\"o\">=</span> <span class=\"n\">paddle</span><span class=\"o\">.</span><span class=\"n\">msort</span><span class=\"p\">(</span><span class=\"nb\">input</span><span class=\"o\">=</span><span class=\"n\">x</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"nb\">print</span><span class=\"p\">(</span><span class=\"n\">out1</span><span class=\"o\">.</span><span class=\"n\">numpy</span><span class=\"p\">())</span>\n<span class=\"go\">[[[5. 2. 4. 2.]</span>\n<span class=\"go\">  [0. 0. 1. 7.]</span>\n<span class=\"go\">  [1. 7. 0. 4.]]</span>\n<span class=\"go\"> [[5. 8. 9. 5.]</span>\n<span class=\"go\">  [4. 7. 7. 9.]</span>\n<span class=\"go\">  [6. 9. 2. 6.]]]</span>\n\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">out2</span> <span class=\"o\">=</span> <span class=\"n\">paddle</span><span class=\"o\">.</span><span class=\"n\">empty_like</span><span class=\"p\">(</span><span class=\"n\">x</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">paddle</span><span class=\"o\">.</span><span class=\"n\">msort</span><span class=\"p\">(</span><span class=\"nb\">input</span><span class=\"o\">=</span><span class=\"n\">x</span><span class=\"p\">,</span> <span class=\"n\">out</span><span class=\"o\">=</span><span class=\"n\">out2</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"nb\">print</span><span class=\"p\">(</span><span class=\"n\">out2</span><span class=\"o\">.</span><span class=\"n\">numpy</span><span class=\"p\">())</span>\n<span class=\"go\">[[[5. 2. 4. 2.]</span>\n<span class=\"go\">  [0. 0. 1. 7.]</span>\n<span class=\"go\">  [1. 7. 0. 4.]]</span>\n<span class=\"go\"> [[5. 8. 9. 5.]</span>\n<span class=\"go\">  [4. 7. 7. 9.]</span>\n<span class=\"go\">  [6. 9. 2. 6.]]]</span>\n</pre>\n</div>\n</div>\n</dd>\n</dl>\n</div>"
