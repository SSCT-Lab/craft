d>\n<dt class=\"field-even\">Returns</dt>\n<dd class=\"field-even\"><p>output (Tensor or tuple of Tensors)</p>\n</dd>\n</dl>\n<p>Example:</p>\n<div class=\"highlight-default notranslate\"><div class=\"highlight\"><pre><span></span><span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">x</span> <span class=\"o\">=</span> <span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">arange</span><span class=\"p\">(</span><span class=\"mi\">2</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">x</span>\n<span class=\"go\">tensor([0, 1])</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">atleast_1d</span><span class=\"p\">(</span><span class=\"n\">x</span><span class=\"p\">)</span>\n<span class=\"go\">tensor([0, 1])</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">x</span> <span class=\"o\">=</span> <span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">tensor</span><span class=\"p\">(</span><span class=\"mf\">1.</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">x</span>\n<span class=\"go\">tensor(1.)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">atleast_1d</span><span class=\"p\">(</span><span class=\"n\">x</span><span class=\"p\">)</span>\n<span class=\"go\">tensor([1.])</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">x</span> <span class=\"o\">=</span> <span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">tensor</span><span class=\"p\">(</span><span class=\"mf\">0.5</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">y</span> <span class=\"o\">=</span> <span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">tensor</span><span class=\"p\">(</span><span class=\"mf\">1.</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">atleast_1d</span><span class=\"p\">((</span><span class=\"n\">x</span><span class=\"p\">,</span> <span class=\"n\">y</span><span class=\"p\">))</span>\n<span class=\"go\">(tensor([0.5000]), tensor([1.]))</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">atleast_1d</span><span class=\"p\">()</span>\n<span class=\"go\">()</span>\n</pre></div>\n</div>\n</dd></dl>\n</div>\n</article>\n</article>\n<footer class=\"bd-footer-article\">\n<div class=\"footer-article-items footer-article__inner\">\n<div class=\"footer-article-item\">\n<div class=\"feedback\">\n<div class=\"rating\">\n    Rate this Page\n    <div class=\"stars\">\n<span class=\"star\" data-behavior=\"tutorial-rating\" data-count=\"1\" data-value=\"1\">★</span>\n<span class=\"star\" data-behavior=\"tutorial-rating\" data-count=\"2\" data-value=\"2\">★</span>\n<span class=\"star\" data-behavior=\"tutorial-rating\" data-count=\"3\" data-value=\"3\">★</span>\n<span class=\"star\" data-behavior=\"tutorial-rating\" data-count=\"4\" data-value=\"4\">★</span>\n<span class=\"star\" data-behavior=\"tutorial-rating\" data-count=\"5\" data-value=\"5\">★</span>\n</div>\n</div>\n<div class=\"feedback-send\">\n<button class=\"feedback-btn\" data-bs-placement=\"bottom\" data-bs-title=\"Create a GitHub Issue\" data-bs-toggle=\"tooltip\" data-gtm=\"feedback-btn-click\" onclick=\"openGitHubIssue()\">Send Feedback\n    </button>\n</div>\n</div>\n<div class=\"prev-next-area\">\n<a class=\"left-prev\" href=\"torch.kaiser_window.html\" title=\"previous page\">\n<i class=\"fa-solid fa-angle-left\"></i>\n<div class=\"prev-next-info\">\n<p class=\"prev-next-subtitle\">previous</p>\n<p class=\"prev-next-title\">torch.kaiser_window</p>\n</div>\n</a>\n<a class=\"right-next\" href=\"torch.atleast_2d.html\" title=\"next page\">\n<div class=\"prev-next-info\">\n<p c