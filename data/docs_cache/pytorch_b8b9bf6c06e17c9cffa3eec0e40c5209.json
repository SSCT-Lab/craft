    },
    {
      "name": "Keyword Arguments:",
      "description": "left(bool,optional) – whether to solve the systemAX=BAX=BAX=BorXA=BXA = BXA=B. Default:True.out(Tensor,optional) – output tensor. Ignored ifNone. Default:None."
    },
