=\"name\"/>\n<meta content=\"1\" itemprop=\"position\"/>\n</div>\n<div itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"https://schema.org/ListItem\">\n<link href=\"../torch.html\" itemprop=\"item\"/>\n<meta content=\"torch\" itemprop=\"name\"/>\n<meta content=\"2\" itemprop=\"position\"/>\n</div>\n<div itemprop=\"itemListElement\" itemscope=\"\" itemtype=\"https://schema.org/ListItem\">\n<meta content=\"torch.manual_seed\" itemprop=\"name\"/>\n<meta content=\"3\" itemprop=\"position\"/>\n</div>\n</div>\n<div id=\"searchbox\"></div>\n<article class=\"bd-article\">\n<section id=\"torch-manual-seed\">\n<h1>torch.manual_seed<a class=\"headerlink\" href=\"#torch-manual-seed\" title=\"Link to this heading\">#</a></h1>\n<dl class=\"py function\">\n<dt class=\"sig sig-object py\" id=\"torch.manual_seed\">\n<span class=\"sig-prename descclassname\"><span class=\"pre\">torch.</span></span><span class=\"sig-name descname\"><span class=\"pre\">manual_seed</span></span><span class=\"sig-paren\">(</span><em class=\"sig-param\"><span class=\"n\"><span class=\"pre\">seed</span></span></em><span class=\"sig-paren\">)</span><a class=\"reference external\" href=\"https://github.com/pytorch/pytorch/blob/v2.10.0/torch/random.py#L32\"><span class=\"viewcode-link\"><span class=\"pre\">[source]</span></span></a><a class=\"headerlink\" href=\"#torch.manual_seed\" title=\"Link to this definition\">#</a></dt>\n<dd><p>Sets the seed for generating random numbers on all devices. Returns a\n<cite>torch.Generator</cite> object.</p>\n<dl class=\"field-list simple\">\n<dt class=\"field-odd\">Parameters<span class=\"colon\">:</span></dt>\n<dd class=\"field-odd\"><p><strong>seed</strong> (<a class=\"reference external\" href=\"https://docs.python.org/3/library/functions.html#int\" title=\"(in Python v3.14)\"><em>int</em></a>) – The desired seed. Value must be within the inclusive range\n<cite>[-0x8000_0000_0000_0000, 0xffff_ffff_ffff_ffff]</cite>. Otherwise, a RuntimeError\nis raised. Negative 