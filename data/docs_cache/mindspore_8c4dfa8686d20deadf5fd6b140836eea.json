/span><span class=\"p\">,</span> <span class=\"kc\">True</span><span class=\"p\">)</span>\n<span class=\"gp\">&gt;&gt;&gt; </span><span class=\"nb\">print</span><span class=\"p\">(</span><span class=\"n\">output</span><span class=\"p\">)</span>\n<span class=\"go\">[[9.02716 ]</span>\n<span class=\"go\"> [7.175515]</span>\n<span class=\"go\"> [8.133643]]</span>\n</pre></div>\n</div>\n</dd></dl>\n</section>\n</div>\n</div>\n<footer><div aria-label=\"Footer\" class=\"rst-footer-buttons\" role=\"navigation\">\n<a accesskey=\"p\" class=\"btn btn-neutral float-left\" href=\"mindspore.ops.logcumsumexp.html\" rel=\"prev\" title=\"mindspore.ops.logcumsumexp\"><span aria-hidden=\"true\" class=\"fa fa-arrow-circle-left\"></span> Previous</a>\n<a accesskey=\"n\" class=\"btn btn-neutral float-right\" href=\"mindspore.ops.max.html\" rel=\"next\" title=\"mindspore.ops.max\">Next <span aria-hidden=\"true\" class=\"fa fa-arrow-circle-right\"></span></a>\n</div>\n<hr/>\n<div role=\"contentinfo\">\n<p>© Copyright MindSpore.</p>\n</div>\n\n  Built with <a href=\"https://www.sphinx-doc.org/\">Sphinx</a> using a\n    <a href=\"https://github.com/readthedocs/sphinx_rtd_theme\">theme</a>\n    provided by <a href=\"https://readthedocs.org\">Read the Docs</a>.\n   \n\n</footer>\n</div>\n</div>\n</section>\n</div>\n<script>\n      jQuery(function () {\n          SphinxRtdTheme.Navigation.enable(true);\n      });\n  </script>\n</body>"
