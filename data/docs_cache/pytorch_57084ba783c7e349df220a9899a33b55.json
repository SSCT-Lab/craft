  "description": "Pad a list of variable length Tensors withpadding_value.",
  "parameters": [
    {
      "name": "Parameters",
      "description": "sequences(list[Tensor]) – list of variable length sequences.batch_first(bool,optional) – ifTrue, the output will be inBxTx*format,TxBx*otherwise.padding_value(float,optional) – value for padded elements. Default:0.padding_side(str,optional) – the side to pad the sequences on.\nDefault:'right'."
    },
    {
      "name": "Returns",
      "description": "Tensor of sizeTxBx*ifbatch_firstisFalse.\nTensor of sizeBxTx*otherwise"
    },
    {
      "name": "Return type",
      "description": "Tensor"
    }
  ],
  "returns": "This function returns a Tensor of sizeTxBx*orBxTx*whereTis the length of the longest sequence. This function assumes\ntrailing dimensions and type of all the Tensors in sequences are same.",
