  "title": "torch.linalg.inv — PyTorch 2.10 documentation",
  "description": "Computes the inverse of a square matrix if it exists.\nThrows aRuntimeErrorif the matrix is not invertible.",
  "parameters": [
    {
      "name": "Parameters:",
      "description": "A(Tensor) – tensor of shape(*, n, n)where*is zero or more batch dimensions\nconsisting of invertible matrices."
    },
    {
      "name": "Keyword Arguments:",
      "description": "out(Tensor,optional) – output tensor. Ignored ifNone. Default:None."
    },
    {
      "name": "Raises:",
      "description": "RuntimeError– if the matrixAor any matrix in the batch of matricesAis not invertible."
    }
  ],
  "returns": "",
