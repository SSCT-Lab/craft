    {
      "name": "Parameters:",
      "description": "A(Tensor) – tensor of shape(*, m, n)where*is zero or more batch dimensions.mode(str,optional) – one of‘reduced’,‘complete’,‘r’.\nControls the shape of the returned tensors. Default:‘reduced’."
    },
    {
      "name": "Keyword Arguments:",
      "description": "out(tuple,optional) – output tuple of two tensors. Ignored ifNone. Default:None."
    },
