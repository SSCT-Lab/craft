  "title": "torch.inner — PyTorch 2.9 documentation",
  "description": "Computes the dot product for 1D tensors. For higher dimensions, sums the product\nof elements frominputandotheralong their last dimension.",
  "parameters": [
    {
      "name": "Parameters",
      "description": "input(Tensor) – First input tensorother(Tensor) – Second input tensor"
    },
    {
      "name": "Keyword Arguments",
      "description": "out(Tensor,optional) – Optional output tensor to write result into. The output\nshape isinput.shape[:-1] + other.shape[:-1]."
    }
  ],
